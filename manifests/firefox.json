{
  "manifest_version": 3,
  "name": "jobmeta — autofill ATS + AI cover letters",
  "short_name": "jobmeta",
  "version": "2.0.0",
  "description": "Apply to jobs faster. Auto-fill forms across supported ATS platforms and draft a tailored cover letter — privacy by default.",
  "homepage_url": "https://extensions.voiddo.com/jobmeta/",
  "author": "vøiddo",
  "browser_specific_settings": {
    "gecko": {
      "id": "jobmeta@voiddo.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["personallyIdentifyingInfo", "websiteContent"],
        "optional": ["technicalAndInteraction"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "jobmeta",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "scripts": ["background/service-worker.js"]
  },
  "options_ui": {
    "page": "pages/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.myworkdayjobs.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.ashbyhq.com/*",
    "https://*.bamboohr.com/*",
    "https://*.icims.com/*",
    "https://*.jobvite.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.successfactors.com/*",
    "https://*.taleo.net/*",
    "https://*.breezy.hr/*",
    "https://*.breezyhr.com/*",
    "https://scrb.voiddo.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.myworkdayjobs.com/*",
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.ashbyhq.com/*",
        "https://*.bamboohr.com/*",
        "https://*.icims.com/*",
        "https://*.jobvite.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.successfactors.com/*",
        "https://*.taleo.net/*",
        "https://*.breezy.hr/*",
        "https://*.breezyhr.com/*"
      ],
      "js": [
        "content/detector.js",
        "content/autofill.js"
      ],
      "css": [
        "content/overlay.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon-32.png",
        "icons/icon-48.png",
        "icons/icon-128.png"
      ],
      "matches": [
        "https://*.myworkdayjobs.com/*",
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.ashbyhq.com/*",
        "https://*.bamboohr.com/*",
        "https://*.icims.com/*",
        "https://*.jobvite.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.successfactors.com/*",
        "https://*.taleo.net/*",
        "https://*.breezy.hr/*",
        "https://*.breezyhr.com/*"
      ]
    }
  ]
}
